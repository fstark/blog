<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1">
<title>{{ title or metadata.title }}</title>
</head>
{% if vintageMode == "color" %}
<body bgcolor="#ffffff" text="#000000" link="#0000cc" vlink="#551a8b" alink="#ff0000">
<table width="100%" cellpadding="0" cellspacing="0" border="0">
<tr><td bgcolor="#336699" valign="middle">
<font face="Geneva, Helvetica, Arial" size="+2" color="#ffffff">&nbsp;<b>{{ metadata.title }}</b></font>
</td></tr>
<tr><td bgcolor="#003366">
<font face="Geneva, Helvetica, Arial" size="2" color="#ffffff">
&nbsp;{%- for entry in collections.all | eleventyNavigation %}
<a href="{{ entry.url }}"><font color="#ffcc00">{{ entry.title }}</font></a>{% if not loop.last %} | {% endif %}
{%- endfor %}
</font>
</td></tr>
</table>
<br>
{% else %}
<body bgcolor="#ffffff" text="#000000" link="#000000" vlink="#000000">
<table width="100%" cellpadding="0" cellspacing="0" border="0">
<tr><td valign="middle">
<font face="Geneva, Helvetica, Arial" size="+2"><b>{{ metadata.title }}</b></font>
</td></tr>
<tr><td>
<font face="Geneva, Helvetica, Arial" size="2">
{%- for entry in collections.all | eleventyNavigation %}
<a href="{{ entry.url }}">{{ entry.title }}</a>{% if not loop.last %} | {% endif %}
{%- endfor %}
</font>
</td></tr>
</table>
<hr size="2" noshade>
{% endif %}

<table width="100%" cellpadding="4" cellspacing="0" border="0">
<tr><td>
<font face="Geneva, Helvetica, Arial" size="2">
{{ content | safe }}
</font>
</td></tr>
</table>

<br>
<hr size="1">
<font face="Geneva, Helvetica, Arial" size="1">
{% if vintageMode == "color" %}
<font color="#666666">{{ metadata.title }} &mdash; Best viewed with Netscape on a vintage Mac
{% if vintageMode == "color" %} | <a href="/bw/">B&amp;W version</a>{% endif %}
</font>
{% else %}
{{ metadata.title }} -- Best viewed on a vintage Mac | <a href="/">Color version</a>
{% endif %}
</font>

</body>
</html>
