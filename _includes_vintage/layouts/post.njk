---
layout: layouts/base.njk
---
<h2>{{ title }}</h2>

<font face="Geneva, Helvetica, Arial" size="2">
<i>{{ page.date | readableDate }}</i>
{%- for tag in tags | filterTagList %}
{%- set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
 | <a href="{{ tagUrl }}">{{ tag }}</a>
{%- endfor %}
</font>
<hr size="1">

{{ content | safe }}

{%- if collections.posts %}
{%- set previousPost = collections.posts | getPreviousCollectionItem %}
{%- set nextPost = collections.posts | getNextCollectionItem %}
{%- if nextPost or previousPost %}
<hr size="1">
<font face="Geneva, Helvetica, Arial" size="2">
{%- if previousPost %}&lt;&lt; <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a>{% endif %}
{%- if previousPost and nextPost %} | {% endif %}
{%- if nextPost %}<a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a> &gt;&gt;{% endif %}
</font>
{%- endif %}
{%- endif %}
